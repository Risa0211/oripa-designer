# このファイルは例（.example）です。
# ローカル開発時は `secrets.toml` にコピーして設定します。
# デプロイ時は Streamlit Cloud の設定画面から同じ内容を貼り付けてください。
#
# ⚠️ secrets.toml は .gitignore で除外されています（絶対にコミットしない）

# ツールにアクセスするための共通パスワード
app_password = "ここにパスワードを設定"

# Google Service Account（credentials.json の中身をそのまま貼り付け）
[gcp_service_account]
type = "service_account"
project_id = "oripa-tool"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "oripa-tool-bot@oripa-tool.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
